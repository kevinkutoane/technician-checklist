# Copy this file to .env and fill in your values
# .env is excluded from git

# HTTP port the server listens on
PORT=3000

# Express session secret — change this to a long random string in production
# e.g. openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# Set to 'production' to enable secure cookies and other production safety guards
NODE_ENV=development

# ─── Email Alert Configuration ────────────────────────────────────────────────
# When flagged equipment is detected in a checklist submission, an alert email
# is sent to ALERT_EMAIL via the SMTP server defined below.
# Leave SMTP_HOST blank to disable email alerts entirely.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=alerts@example.com
SMTP_PASS=your-smtp-password
ALERT_EMAIL=it-manager@example.com
FROM_EMAIL=noreply@example.com
