{
  "name": "technician-checklist",
  "version": "1.0.0",
  "description": "Mobile-friendly daily equipment checklist web application for technicians",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "seed": "node db/seed.js",
    "dev": "node server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "middleware/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 85,
        "branches": 80
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "text-summary"
    ]
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "better-sqlite3-session-store": "^0.1.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.17.3",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "pdfkit": "^0.18.0",
    "xlsx": "^0.18.5"
  }
}
